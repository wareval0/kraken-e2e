{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "//#lint": {}
  },
  "globalPassThroughEnv": ["ANDROID_HOME", "ANDROID_SDK_ROOT"]
}
