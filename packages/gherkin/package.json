{
  "name": "@kraken-e2e/gherkin",
  "version": "3.1.0",
  "description": "BDD front-end: .feature parsing (official Gherkin stack), typed step registry, scenario compiler, built-in choreography steps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kraken-e2e/contracts": "workspace:*",
    "@kraken-e2e/core": "workspace:*",
    "@cucumber/cucumber-expressions": "catalog:",
    "@cucumber/gherkin": "catalog:",
    "@cucumber/messages": "catalog:",
    "@cucumber/tag-expressions": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "GPL-3.0-only"
}
