{
  "name": "@kraken-e2e/doctor",
  "version": "3.1.0",
  "description": "Pure check-execution engine for kraken doctor. Inputs (HostInfo, driver gate statuses, driver-contributed checks) are injected by the CLI — this package never reads process.platform and never knows Appium (ADR-0001 §5.13)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kraken-e2e/contracts": "workspace:*",
    "@kraken-e2e/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "GPL-3.0-only"
}
