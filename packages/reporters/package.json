{
  "name": "@kraken-e2e/reporters",
  "version": "3.1.0",
  "description": "Reporter projections of the KrakenEvent stream: JSONL, plain-line, Allure 3, CTRF",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "allure-js-commons": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@kraken-e2e/contracts": "workspace:*",
    "ajv": "catalog:",
    "ajv-formats": "catalog:"
  },
  "peerDependencies": {
    "@kraken-e2e/contracts": "workspace:^"
  },
  "license": "GPL-3.0-only"
}
