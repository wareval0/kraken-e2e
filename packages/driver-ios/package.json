{
  "name": "@kraken-e2e/driver-ios",
  "version": "3.1.0",
  "description": "iOS driver: Appium 3 + appium-xcuitest-driver (hostRequirements: darwin — macOS only, Apple platform restriction)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@kraken-e2e/contracts": "workspace:^"
  },
  "devDependencies": {
    "@kraken-e2e/contracts": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@kraken-e2e/core": "workspace:*"
  },
  "dependencies": {
    "appium": "3.5.2",
    "appium-xcuitest-driver": "11.17.1",
    "webdriverio": "catalog:"
  },
  "license": "GPL-3.0-only"
}
