{
  "name": "@kraken-e2e/cli",
  "version": "3.0.0",
  "description": "The kraken CLI (oclif): run, doctor, init, plugins — the composition layer wiring all packages together",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kraken-e2e/contracts": "workspace:*",
    "@kraken-e2e/core": "workspace:*",
    "@kraken-e2e/signaling": "workspace:*",
    "@kraken-e2e/gherkin": "workspace:*",
    "@kraken-e2e/config": "workspace:*",
    "@kraken-e2e/doctor": "workspace:*",
    "@kraken-e2e/reporters": "workspace:*",
    "@kraken-e2e/tui": "workspace:*",
    "@oclif/core": "catalog:",
    "jiti": "catalog:",
    "tinyglobby": "catalog:",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@types/ws": "catalog:"
  },
  "bin": {
    "kraken": "./bin/run.js"
  },
  "oclif": {
    "bin": "kraken",
    "dirname": "kraken",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "license": "GPL-3.0-only"
}
